    {
      "name": "Practice Workflow",
      "description": "Follow these requests in order to practice a complete CRUD workflow",
      "item": [
        {
          "name": "Step 1 - Check All Tasks",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:5000/tasks",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["tasks"]
            },
            "description": "Start here: View all existing tasks"
          }
        },
        {
          "name": "Step 2 - Add Your First Task",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"My First Task\"\n}"
            },
            "url": {
              "raw": "http://localhost:5000/tasks",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["tasks"]
            },
            "description": "Create a new task. Take note of the ID returned!"
          }
        },
        {
          "name": "Step 3 - Get Your New Task",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:5000/tasks/4",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["tasks", "4"]
            },
            "description": "Retrieve the task you just created. Update '4' to the ID from Step 2 if different."
          }
        },
        {
          "name": "Step 4 - Update Your Task",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"My First Task - Updated\",\n  \"completed\": true\n}"
            },
            "url": {
              "raw": "http://localhost:5000/tasks/4",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["tasks", "4"]
            },
            "description": "Update the task. Use the ID from Step 2."
          }
        },
        {
          "name": "Step 5 - View All Tasks Again",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:5000/tasks",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["tasks"]
            },
            "description": "See all tasks including your updates"
          }
        },
        {
          "name": "Step 6 - Delete Your Task",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "http://localhost:5000/tasks/4",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["tasks", "4"]
            },
            "description": "Delete the task you created. Use the ID from Step 2."
          }
        },
        {
          "name": "Step 7 - Verify Deletion",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:5000/tasks",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["tasks"]
            },
            "description": "Confirm the task is gone. The task should no longer appear in the list."
          }
        }
      ]
    }
